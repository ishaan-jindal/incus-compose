name: with-nat-proxy
services:
  web:
    image: docker.io/nginx:alpine
    networks:
      frontend:
        ipv4_address: 10.139.38.17
    ports:
      - mode: ingress
        target: 80
        published: "2856"
        protocol: tcp
      - mode: ingress
        target: 443
        published: "2456"
        protocol: tcp
    x-incus-compose:
      nat-proxy:
        - connect: 80
          port: 2856
        - connect: 443
          port: 2456
networks:
  frontend:
    name: with-nat-proxy_frontend
    x-incus:
      ipv4.address: 10.139.38.1/24
