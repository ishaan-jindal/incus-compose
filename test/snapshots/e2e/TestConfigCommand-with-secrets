project:
  name: test-local-config
  services:
    app:
      image: docker.io/library/busybox:glibc
      networks:
        default: null
      secrets:
        - source: demo_secret
          target: /run/secrets/demo_secret
        - source: db_password
          target: /run/secrets/db_password
        - source: api_key
          target: /app/secrets/api.key
          uid: "1000"
          gid: "1000"
          mode: "0644"
  networks:
    default:
      name: test-local-config_default
  secrets:
    api_key:
      name: test-local-config_api_key
      file: $FIXTURE_PATH/api_key.txt
    db_password:
      name: test-local-config_db_password
      file: $FIXTURE_PATH/db_password.txt
    demo_secret:
      name: test-local-config_demo_secret
      environment: DEMO_SECRET
