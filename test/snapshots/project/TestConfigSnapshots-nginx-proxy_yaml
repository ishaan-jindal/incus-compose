name: nginx-proxy
services:
  backend1:
    environment:
      NGINX_ENTRYPOINT_WORKER_PROCESSES_AUTOTUNE: "1"
    healthcheck:
      test:
        - CMD
        - wget
        - -q
        - --spider
        - http://127.0.0.1:8080
      timeout: 5s
      interval: 5s
      retries: 3
    image: docker.io/nginxinc/nginx-unprivileged:alpine
    networks:
      default: null
    restart: unless-stopped
    x-incus:
      limits.cpu: 1
  backend2:
    environment:
      NGINX_ENTRYPOINT_WORKER_PROCESSES_AUTOTUNE: "1"
    healthcheck:
      test:
        - CMD
        - wget
        - -q
        - --spider
        - http://127.0.0.1:8080
      timeout: 5s
      interval: 5s
      retries: 3
    image: docker.io/nginxinc/nginx-unprivileged:alpine
    networks:
      default: null
    restart: unless-stopped
    x-incus:
      limits.cpu: 1
  nginx:
    depends_on:
      backend1:
        condition: service_healthy
        required: true
      backend2:
        condition: service_healthy
        required: true
    environment:
      NGINX_ENTRYPOINT_WORKER_PROCESSES_AUTOTUNE: "1"
    healthcheck:
      test:
        - CMD
        - wget
        - -q
        - --spider
        - http://127.0.0.1:8080
      timeout: 5s
      interval: 5s
      retries: 3
    image: docker.io/nginxinc/nginx-unprivileged:alpine
    networks:
      default: null
    restart: unless-stopped
    x-incus:
      limits.cpu: 1
networks:
  default:
    name: nginx-proxy_default
