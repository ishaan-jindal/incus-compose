[
  {
    "label": "Run config",
    "adapter": "Delve",
    "request": "launch",
    "mode": "debug",
    // For Delve, the program can be a package name
    "program": "./cmd/incus-compose",
    "args": ["--debug", "config", "--format", "json"],
    // "buildFlags": [],
  },
  {
    "label": "Run ps (nested)",
